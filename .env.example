# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL for email links (password reset, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Full mock test (learners): optional hard close, or flip public launch before the default date (22 Apr 2026 +07:00).
# NEXT_PUBLIC_MOCK_TEST_CLOSED=true
# NEXT_PUBLIC_MOCK_TEST_PUBLIC_LAUNCH=true

# Mock test engine v2 (4-stage pool placement). Requires migration 011 + pool rows with target_band.
# NEXT_PUBLIC_MOCK_TEST_ENGINE_V2=true

# One-time POST /api/admin/setup — header x-setup-secret
ADMIN_SETUP_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: Gemini
GEMINI_API_KEY=
# Optional: Anthropic — required when admin selects a Claude id (e.g. claude-haiku-4-5) for grading.
# ANTHROPIC_API_KEY=
# Text model when no row in admin_settings (see /admin — “AI grading model”).
# Example preview model: gemini-3.1-pro-preview
# GEMINI_MODEL=gemini-2.5-flash
# TTS / speech synthesis (separate from grading + transcription):
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Inworld TTS (default for /api/speech-synthesize when set — server-side; optional header x-inworld-api-key)
# Portal: Settings → API Keys. Use the Base64 credential with Authorization: Basic … (do not expose to the browser).
INWORLD_API_KEY=
# Optional overrides (defaults: Sarah, inworld-tts-1.5-max, speaking rate 0.99, temperature 1; HTTP stream then sync fallback)
# INWORLD_VOICE_ID=Sarah
# INWORLD_TTS_MODEL_ID=inworld-tts-1.5-max
# INWORLD_SPEAKING_RATE=0.99
# INWORLD_TTS_TEMPERATURE=1
# INWORLD_USE_STREAM=true

# Optional: ElevenLabs TTS (provider=elevenlabs, or reorder interactive speaking below)
# https://elevenlabs.io
ELEVENLABS_API_KEY=
# Comma-separated try order for interactive speaking TTS (default: inworld → gemini → elevenlabs).
# If ElevenLabs runs every time, you probably set ElevenLabs first here — remove the line or use inworld,gemini,elevenlabs.
# Production needs INWORLD_API_KEY or the first step fails and the app falls through to the next provider.
# NEXT_PUBLIC_INTERACTIVE_SPEAKING_TTS_ORDER=elevenlabs,inworld,gemini
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32

# Admin login on /login (no Supabase email): POST body code must match.
# Optional: ADMIN_ACCESS_SECRET signs the httpOnly cookie (defaults to same as code).
ADMIN_LOGIN_CODE=englishplanforever
# ADMIN_ACCESS_SECRET=

# Duolingo Fast Track — self-serve VIP (6 months) on / landing modal
# Required: shared secret students enter as passcode.
DUOLINGO_FAST_TRACK_PASSCODE=
# Either allow any email that knows the passcode:
# DUOLINGO_FAST_TRACK_OPEN_ENROLLMENT=true
# Or restrict to a list (comma-separated, case-insensitive):
# DUOLINGO_FAST_TRACK_ALLOWED_EMAILS=student1@example.com,student2@example.com
# Or a single address:
# DUOLINGO_FAST_TRACK_ALLOWED_EMAIL=cohort@example.com
# Fast Track does not send VIP “grant” notification emails; students sign in with Google and see VIP in-app.
